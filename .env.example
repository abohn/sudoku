# YouTube Data API v3 key
# Get one at https://console.cloud.google.com
YOUTUBE_API_KEY=your_api_key_here

# Cracking the Cryptic channel handle (or channel ID if you prefer)
CTC_CHANNEL_ID=@crackingthecryptic

# How many months back to crawl on first run (0 = all time)
CRAWL_MONTHS_BACK=3

# Database file path
DATABASE_URL=sqlite:///./data/sudoku.db

# Backend API URL (used by frontend build)
VITE_API_URL=http://localhost:8000
